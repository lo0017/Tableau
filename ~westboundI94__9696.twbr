      <aliases enabled='yes' />
      <column caption='Day Type' datatype='string' name='[Calculation_0666349571788800]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;month&apos;,[date_time]) = 1 &#13;&#10;AND DATEPART(&apos;day&apos;,[date_time]) = 1&#13;&#10;THEN &quot;New Year&apos;s Day&quot;&#13;&#10;ELSE &quot;All Other Days&quot;&#13;&#10;END' />
      </column>
      <column caption='Weather Category' datatype='string' name='[Calculation_0666349589041154]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [weather_main] IN (&quot;Rain&quot;, &quot;Snow&quot;, &quot;Thunderstorm&quot;, &quot;Drizzle&quot;)&#13;&#10;THEN &quot;Adverse Weather&quot;&#13;&#10;ELSE &quot;Normal Weather&quot;&#13;&#10;END' />
      </column>
      <column caption='Fahrenheit' datatype='real' name='[Calculation_1347496688201728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([temp] - 273.15) * 9/5 + 32' />
      </column>
      <column caption='Rain Level' datatype='string' name='[Calculation_1347496693383169]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rain_1h] = 0 THEN &quot;No Rain&quot;&#13;&#10;ELSEIF [rain_1h] &lt; 2 THEN &quot;Light Rain&quot;&#13;&#10;ELSEIF [rain_1h] &lt; 5 THEN &quot;Moderate Rain&quot;&#13;&#10;ELSE &quot;Heavy Rain&quot;&#13;&#10;END' />
      </column>
      <column caption='Hour of Day' datatype='integer' name='[Calculation_1347496693784578]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [date_time])' />
      </column>
      <column caption='Temperature (F)' datatype='real' name='[Calculation_1347496696532995]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([temp] - 273.15) * 9/5 + 32' />
      </column>
      <column caption='Temperature Category' datatype='string' name='[Calculation_1347496696741892]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1347496696532995] &lt; 32 THEN &quot;Below Freezing&quot;&#13;&#10;ELSEIF [Calculation_1347496696532995] &lt; 60 THEN &quot;Cold&quot;&#13;&#10;ELSEIF [Calculation_1347496696532995] &lt; 80 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Hot&quot;&#13;&#10;END' />
      </column>
