    <worksheet name='Sheet 9'>
      <layout-options>
        <title>
          <formatted-text>
            <run>New Years Day Traffic Volume by the Hour</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Metro_Interstate_Traffic_Volume' name='federated.0jxf4si0k1taan1ffctch1ipg6uq' />
          </datasources>
          <datasource-dependencies datasource='federated.0jxf4si0k1taan1ffctch1ipg6uq'>
            <column caption='Day Type' datatype='string' name='[Calculation_0666349571788800]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF DATEPART(&apos;month&apos;,[date_time]) = 1 &#13;&#10;AND DATEPART(&apos;day&apos;,[date_time]) = 1&#13;&#10;THEN &quot;New Year&apos;s Day&quot;&#13;&#10;ELSE &quot;All Other Days&quot;&#13;&#10;END' />
            </column>
