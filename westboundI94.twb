              <calculation class='tableau' formula='IF [weather_main] IN (&quot;Rain&quot;, &quot;Snow&quot;, &quot;Thunderstorm&quot;, &quot;Drizzle&quot;)&#13;&#10;THEN &quot;Adverse Weather&quot;&#13;&#10;ELSE &quot;Normal Weather&quot;&#13;&#10;END' />
